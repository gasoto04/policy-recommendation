        ],
        "table_body": "\n\n<html><body><table><tr><td rowspan=\"3\"></td><td>2019</td><td>2020</td></tr><tr><td>End-Dec.</td><td>End-Mar.</td></tr><tr><td colspan=\"2\">(in CFAF Billion)</td></tr><tr><td>Net Oil Revenuei 1</td><td>359</td><td>133</td></tr><tr><td>Budget Grants</td><td>50</td><td>35</td></tr><tr><td>Budget Loans</td><td>13</td><td>0</td></tr><tr><td>Exceptional Receipt</td><td>0</td><td>0</td></tr><tr><td>Total</td><td>422</td><td>168</td></tr></table></body></html>\n\n",
        "page_idx": 58
